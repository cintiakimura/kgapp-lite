# SQLite file for local prototype (path relative to project root)
DATABASE_URL="file:./dev.db"

# Instructor invitations (Company dashboard → Send Invites)
# From address — required for any send (Resend: use your verified domain or onboarding@resend.dev)
EMAIL_FROM="KG App <onboarding@resend.dev>"

# Option A: Resend (https://resend.com) — recommended for development
RESEND_API_KEY=""

# Option B: SMTP (used when RESEND_API_KEY is unset)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""

# Link in invitation emails when the client does not pass dashboardUrl
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to 1 to log who would receive mail without sending (API still validates JSON)
# INVITE_DRY_RUN="0"
